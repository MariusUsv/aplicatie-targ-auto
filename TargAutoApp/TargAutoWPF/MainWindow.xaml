<Window x:Class="TargAutoWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoConnect - Gestiune Târg Auto" Height="850" Width="1300" 
        Background="#0F172A" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="14">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBG" Color="#1E293B"/>
        <SolidColorBrush x:Key="Accent" Color="#38BDF8"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#334155"/>

        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#334155"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0B1120"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,5,0,12"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ElegantButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,0,0,1">
            <TextBlock Text="🚘 AutoConnect" Foreground="{StaticResource Accent}" FontSize="24" FontWeight="Bold" Margin="30,0" VerticalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="10">
            <TabItem Header="📋 TRANZACȚII">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource CardBG}" CornerRadius="15" Margin="10" Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Detalii Tranzacție" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                                <Label Content="Vânzător" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox x:Name="txtVanzator"/>
                                <Label Content="Cumpărător" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox x:Name="txtCumparator"/>
                                <Label Content="Marcă" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox x:Name="txtFirma"/>
                                <Label Content="Model" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox x:Name="txtModel"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                        <Label Content="An" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox x:Name="txtAn"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                        <Label Content="Preț (€)" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox x:Name="txtPret"/>
                                    </StackPanel>
                                </Grid>
                                <DatePicker x:Name="dpDataTranzactie" Margin="0,10,0,20"/>
                                <Button Content="ADĂUGĂ" Click="btnAdauga_Click" Background="{StaticResource Accent}" Style="{StaticResource ElegantButton}" Margin="0,0,0,10"/>
                                <Button Content="ȘTERGE SELECTATĂ" Click="btnSterge_Click" Background="#EF4444" Style="{StaticResource ElegantButton}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource CardBG}" CornerRadius="15" Margin="10" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Label Content="Model:" Foreground="White" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtCautare" Width="120" Margin="10,0,20,0" TextChanged="Filtre_Changed"/>
                                <Label Content="Preț Max:" Foreground="White" VerticalAlignment="Center"/>
                                <Slider x:Name="slPretFiltru" Width="150" Minimum="0" Maximum="100000" Value="100000" VerticalAlignment="Center" ValueChanged="Filtre_Changed"/>
                                <TextBlock Text="{Binding ElementName=slPretFiltru, Path=Value, StringFormat={}{0:N0} €}" Foreground="{StaticResource Accent}" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <DataGrid x:Name="dgTranzactii" Grid.Row="1" ItemsSource="{Binding TranzactiiOC}" AutoGenerateColumns="False" IsReadOnly="True" ColumnHeaderStyle="{StaticResource HeaderStyle}" Background="Transparent" Foreground="White" BorderThickness="0" RowBackground="#1E293B" SelectionChanged="dgTranzactii_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Marcă" Binding="{Binding Masina.Firma}" Width="*"/>
                                    <DataGridTextColumn Header="Model" Binding="{Binding Masina.Model}" Width="*"/>
                                    <DataGridTextColumn Header="Preț" Binding="{Binding Pret}" Width="100"/>
                                    <DataGridTextColumn Header="Data" Binding="{Binding DataTranzactie, StringFormat=dd.MM.yy}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="👥 CLIENȚI">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource CardBG}" CornerRadius="15" Margin="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Administrare Client" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Label Content="Nume" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="txtNumePersoana"/>
                            <Label Content="Telefon" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="txtTelefonPersoana"/>
                            <Label Content="Email" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox x:Name="txtEmailPersoana"/>
                            <Button Content="SALVEAZĂ CLIENT" Click="btnAdaugaPersoana_Click" Background="{StaticResource Accent}" Style="{StaticResource ElegantButton}" Margin="0,10,0,20"/>
                            <TextBlock Text="Istoric Tranzacții" Foreground="{StaticResource Accent}" FontWeight="Bold" Margin="0,0,0,10"/>
                            <DataGrid x:Name="dgIstoricClient" Height="250" AutoGenerateColumns="False" IsReadOnly="True" ColumnHeaderStyle="{StaticResource HeaderStyle}" Background="#0F172A" Foreground="White" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mașină" Binding="{Binding Masina.Model}" Width="*"/>
                                    <DataGridTextColumn Header="Preț" Binding="{Binding Pret}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource CardBG}" CornerRadius="15" Margin="10" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="txtCautareClient" Grid.Row="0" Margin="0,0,0,15" TextChanged="txtCautareClient_TextChanged" ToolTip="Caută nume..."/>
                            <ListBox x:Name="lstPersoane" Grid.Row="1" ItemsSource="{Binding PersoaneOC}" DisplayMemberPath="Nume" SelectionChanged="lstPersoane_SelectionChanged" Background="Transparent" Foreground="White" BorderThickness="0"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border x:Name="NotificareCard" Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Background="#10B981" CornerRadius="10" Padding="25,12" Margin="0,0,0,40" Visibility="Collapsed">
            <TextBlock x:Name="txtNotificare" Foreground="White" FontWeight="Bold"/>
        </Border>
    </Grid>
</Window>